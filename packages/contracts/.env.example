# Private key of the deployer wallet (WITHOUT 0x prefix)
# WARNING: Never commit this file with real values!
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ── Mezo Testnet (chain 31611) ────────────────────────────────────────────────
MEZO_TESTNET_RPC_URL=https://rpc.test.mezo.org
MEZO_TESTNET_WSS_URL=wss://rpc-ws.test.mezo.org

# ── Mezo Mainnet (chain 31612) — choose one RPC provider ────────────────────
# Boar Network (default)
MEZO_MAINNET_RPC_URL=https://rpc-http.mezo.boar.network
MEZO_MAINNET_WSS_URL=wss://rpc-ws.mezo.boar.network

# Imperator (alternative)
# MEZO_MAINNET_RPC_URL=https://rpc_evm-mezo.imperator.co
# MEZO_MAINNET_WSS_URL=wss://ws_evm-mezo.imperator.co

# Validation Cloud (alternative)
# MEZO_MAINNET_RPC_URL=https://mainnet.mezo.public.validationcloud.io
# MEZO_MAINNET_WSS_URL=wss://mainnet.mezo.public.validationcloud.io

# dRPC NodeCloud (alternative)
# MEZO_MAINNET_RPC_URL=https://mezo.drpc.org
# MEZO_MAINNET_WSS_URL=wss://mezo.drpc.org

# Block explorer API key for contract verification
MEZO_EXPLORER_API_KEY=
