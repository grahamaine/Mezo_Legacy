{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "compile": {
      "dependsOn": [],
      "outputs": ["artifacts/**", "cache/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["compile"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}